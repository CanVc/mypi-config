diff -ruN a/src/shared/formatters.ts ./src/shared/formatters.ts
--- a/shared/formatters.ts	2026-05-13 09:49:50.463559338 +0200
+++ b/src/shared/formatters.ts	2026-05-13 09:50:18.791306352 +0200
@@ -118,3 +118,72 @@
 	}
 	return p;
 }
+
+/**
+ * Build a concise task summary from a (possibly injected) task string.
+ *
+ * Strips or avoids framework-injected noise such as fork preambles,
+ * [Read from:], [Write to:], progress instructions, output instructions,
+ * and {previous} placeholder content. Returns a clean, width-appropriate
+ * summary suitable for compact display rows.
+ */
+export function buildTaskSummary(task: string, maxLength = 80): string {
+	if (!task) return "";
+
+	let clean = task;
+
+	// Strip fork preamble: "<preamble>\n\nTask:\n<actual task>"
+	const forkTaskMarker = "\n\nTask:\n";
+	const forkIdx = clean.indexOf(forkTaskMarker);
+	if (forkIdx >= 0) {
+		clean = clean.slice(forkIdx + forkTaskMarker.length);
+	}
+
+	// Strip [Read from: ...] lines
+	clean = clean.replace(/^\[Read from:[^\]]*\]\s*\n?/gim, "");
+
+	// Strip [Write to: ...] lines
+	clean = clean.replace(/^\[Write to:[^\]]*\]\s*\n?/gim, "");
+
+	// Strip output/progress instruction lines, including labeled injected forms such as
+	// "**Output:** Write your findings to: ..."
+	clean = clean.replace(/^(?:\*\*[^*]+:\*\*\s*)?Write your (?:progress|findings|output) to:[^\n]*\n?/gim, "");
+
+	// Strip chain progress instruction lines, with or without a markdown label prefix.
+	clean = clean.replace(/^(?:\*\*[^*]+:\*\*\s*)?(?:Create and maintain progress at|Update progress at):[^\n]*\n?/gim, "");
+
+	// Strip everything from "Previous step output:" onward (includes long prior content)
+	clean = clean.replace(/\nPrevious step output:[\s\S]*$/im, "");
+
+	// Strip horizontal rule separators used to delimit injected sections
+	clean = clean.replace(/^\s*---\s*$/gm, "");
+
+	// Strip "{previous}" placeholder — often expands to very long prior output.
+	// If the task is dominated by a {previous} substitution, take the first line only.
+	const prevIdx = clean.indexOf("{previous}");
+	if (prevIdx >= 0) {
+		// Keep text before {previous} if it exists, otherwise the task is just a reference
+		const before = clean.slice(0, prevIdx).trim();
+		if (before) {
+			clean = before;
+		} else {
+			// The entire task is a {previous} reference — describe generically
+			clean = "continue from previous output";
+		}
+	}
+
+	// Strip leading/trailing whitespace, collapse internal whitespace
+	clean = clean.replace(/\n{2,}/g, "\n").trim();
+
+	// Take the first meaningful line
+	const firstLine = clean.split("\n").find((l) => l.trim())?.trim() ?? "";
+
+	if (!firstLine) return "";
+
+	// Truncate to maxLength
+	if (firstLine.length > maxLength) {
+		return firstLine.slice(0, maxLength - 1) + "…";
+	}
+
+	return firstLine;
+}
