+export function sanitizeUiTitle(value: string | undefined, maxLength = 120): string {
+	const stripped = (value ?? "")
+		.replace(ANSI_PATTERN, "")
+		.replace(CONTROL_PATTERN, " ")
+		.replace(/\s+/g, " ")
+		.trim();
+	if (stripped.length <= maxLength) return stripped;
+	return `${stripped.slice(0, Math.max(1, maxLength - 1)).trimEnd()}…`;
+}
+
+export function resolveAgentRoleLabel(agent: Pick<AgentConfig, "name" | "localName" | "extraFields"> | undefined, fallbackAgent?: string): string {
+	const roleLabel = sanitizeUiTitle(agent?.extraFields?.roleLabel, 80);
+	if (roleLabel) return roleLabel;
+	return sanitizeUiTitle(agent?.localName ?? agent?.name ?? fallbackAgent ?? "unknown-agent", 80) || "unknown-agent";
+}
+
+export function runtimeRoleLabel(input: { roleLabel?: string; agent?: string } | undefined, fallbackAgent?: string): string {
+	return sanitizeUiTitle(input?.roleLabel, 80) || sanitizeUiTitle(input?.agent ?? fallbackAgent ?? "unknown-agent", 80) || "unknown-agent";
+}
+
+function unquoteYamlScalar(value: string): string {
+	const trimmed = value.trim();
+	if ((trimmed.startsWith('"') && trimmed.endsWith('"')) || (trimmed.startsWith("'") && trimmed.endsWith("'"))) {
+		return trimmed.slice(1, -1);
+	}
+	if (trimmed === "null") return "";
+	return trimmed;
+}
+
+function parseInlineYamlValue(value: string): string | string[] | null {
+	const trimmed = value.trim();
+	if (trimmed === "null") return null;
+	if (trimmed.startsWith("[") && trimmed.endsWith("]")) {
+		const inner = trimmed.slice(1, -1).trim();
+		if (!inner) return [];
+		return inner.split(",").map((part) => unquoteYamlScalar(part.trim())).filter(Boolean);
+	}
+	return unquoteYamlScalar(trimmed);
+}
+
+function taskStateYamlBlocks(markdown: string): string[] {
+	const taskState = markdown.match(/### Task State\s*```yaml\s*([\s\S]*?)```/i);
+	if (taskState?.[1]) return [taskState[1]];
+	return [...markdown.matchAll(/```yaml\s*([\s\S]*?tasks:\s*[\s\S]*?)```/gi)].map((match) => match[1] ?? "");
+}
+
+function hasRequiredContextSource(task: Record<string, unknown>): boolean {
+	return Object.hasOwn(task, "contextSource")
+		&& task.type === "artifact-path"
+		&& Array.isArray(task.paths)
+		&& task.paths.some((entry) => typeof entry === "string" && entry.trim().length > 0);
+}
+
+function roleLabelMapForTaskStatePath(taskStatePath: string): Map<string, string> {
+	try {
+		const cwd = path.dirname(path.resolve(taskStatePath));
+		const roleLabels = new Map<string, string>();
+		for (const agent of discoverAgents(cwd, "both").agents) {
+			const roleLabel = resolveAgentRoleLabel(agent, agent.name);
+			roleLabels.set(agent.name, roleLabel);
+			if (agent.localName) roleLabels.set(agent.localName, roleLabel);
+		}
+		return roleLabels;
+	} catch {
+		return new Map();
+	}
+}
+
+function applyConfiguredRoleLabels(projection: UiTaskProjection, roleLabels: Map<string, string>): UiTaskProjection {
+	if (projection.degradedReason || roleLabels.size === 0) return projection;
+	return {
+		tasks: projection.tasks.map((task) => {
+			const roleLabel = roleLabels.get(task.activeAgentId ?? "") ?? roleLabels.get(task.targetAgent);
+			if (!roleLabel) return task;
+			return {
+				...task,
+				roleLabel,
+				activityTitle: formatActivityTitle({ roleLabel, taskId: task.taskId, title: task.title }),
+			};
+		}),
+	};
+}
+
+export function parseDurableTaskState(markdown: string): UiTaskProjection {
+	const blocks = taskStateYamlBlocks(markdown);
+	if (blocks.length === 0) return { degradedReason: "BMAD task state artifact has no readable yaml tasks block", tasks: [] };
+	const block = blocks[0]!;
+	const tasks: Array<Record<string, unknown>> = [];
+	let current: Record<string, unknown> | null = null;
+	let inPaths = false;
+	for (const rawLine of block.split("\n")) {
+		const line = rawLine.replace(/\t/g, "    ");
+		const trimmed = line.trim();
+		if (!trimmed || trimmed.startsWith("#") || trimmed === "tasks:") continue;
+		const itemMatch = line.match(/^\s*-\s+taskId:\s*(.+)$/);
+		if (itemMatch) {
+			current = { taskId: parseInlineYamlValue(itemMatch[1]!) };
+			tasks.push(current);
+			inPaths = false;
+			continue;
+		}
+		if (!current) continue;
+		const kv = line.match(/^\s{4,}([A-Za-z][A-Za-z0-9]*):\s*(.*)$/);
+		if (kv) {
+			const key = kv[1]!;
+			const value = kv[2] ?? "";
+			if (key === "paths") {
+				inPaths = true;
+				current.paths = [];
+				continue;
+			}
+			inPaths = false;
+			current[key] = parseInlineYamlValue(value);
+			continue;
+		}
+		if (inPaths) {
+			const pathMatch = line.match(/^\s*-\s*(.+)$/);
+			if (pathMatch && Array.isArray(current.paths)) current.paths.push(unquoteYamlScalar(pathMatch[1]!));
+		}
+	}
+	if (tasks.length === 0) return { degradedReason: "BMAD task state artifact contains no task records", tasks: [] };
+	const projected: UiTaskDisplay[] = [];
+	for (const task of tasks) {
+		const taskId = typeof task.taskId === "string" ? task.taskId : "";
+		const title = typeof task.title === "string" ? task.title : "";
+		const targetAgent = typeof task.targetAgent === "string" ? task.targetAgent : "";
+		const status = typeof task.status === "string" ? task.status : "";
+		if (!taskId || !title || !targetAgent || !DURABLE_STATUSES.has(status as DurableTaskStatus)) {
+			return { degradedReason: `BMAD task state artifact has malformed task or invalid status '${status || "missing"}'`, tasks: [] };
+		}
+		if (!hasRequiredContextSource(task)) {
+			return { degradedReason: `BMAD task state artifact has malformed task '${taskId || "unknown"}': missing required contextSource`, tasks: [] };
+		}
+		const activeAgentId = typeof task.activeAgentId === "string" && task.activeAgentId ? task.activeAgentId : null;
+		projected.push({
+			taskId,
+			title,
+			targetAgent,
+			activeAgentId,
+			durableStatus: status as DurableTaskStatus,
+			activityTitle: formatActivityTitle({ roleLabel: activeAgentId ?? targetAgent, taskId, title }),
+		});
+	}
+	return { tasks: projected };
+}
+
+export function readDurableTaskProjection(taskStatePath: string | undefined): UiTaskProjection {
+	if (!taskStatePath) return { degradedReason: "BMAD task state artifact path was not provided", tasks: [] };
+	try {
+		const resolved = path.resolve(taskStatePath);
+		const markdown = fs.readFileSync(resolved, "utf-8");
+		return applyConfiguredRoleLabels(parseDurableTaskState(markdown), roleLabelMapForTaskStatePath(resolved));
+	} catch (error) {
+		const message = error instanceof Error ? error.message : String(error);
+		return { degradedReason: `BMAD task state artifact unavailable: ${message}`, tasks: [] };
+	}
+}
+
+export function formatActivityTitle(input: { roleLabel?: string; activeAgentId?: string | null; targetAgent?: string; taskId?: string; title?: string; degradedReason?: string }, maxLength = 120): string {
+	const agent = sanitizeUiTitle(input.roleLabel || input.activeAgentId || input.targetAgent || "unknown-agent", 80) || "unknown-agent";
+	const taskId = sanitizeUiTitle(input.taskId || "unknown-task", 48) || "unknown-task";
+	const title = input.degradedReason ? `degraded: ${input.degradedReason}` : sanitizeUiTitle(input.title || "unknown task", 160);
+	return sanitizeUiTitle(`${agent} · ${taskId} · ${title}`, maxLength);
+}
+
+export function choosePrimaryRuntimeProgress(details: { progress?: AgentProgress[]; results?: SingleResult[] }): AgentProgress | SingleResult | undefined {
+	return details.progress?.find((progress) => progress.status === "running")
+		?? details.results?.find((result) => result.progress?.status === "running")?.progress
+		?? details.results?.find((result) => result.progress?.status === "running")
+		?? details.results?.[0];
+}
+
+function runtimeAgentId(runtime: AgentProgress | SingleResult | undefined): string | undefined {
+	return runtime?.agent;
+}
+
+function runtimeTaskSummary(runtime: AgentProgress | SingleResult | undefined): string | undefined {
+	return sanitizeUiTitle(runtime?.taskSummary || (runtime && "task" in runtime ? buildTaskSummary(runtime.task) : undefined), 80);
+}
+
+type AsyncRuntimeStep = NonNullable<AsyncStatus["steps"]>[number];
+
+function runtimeDurableTaskId(runtime: RuntimeVisibilityItem | undefined): string | undefined {
+	if (!runtime || !("durableTaskId" in runtime)) return undefined;
+	return typeof runtime.durableTaskId === "string" && runtime.durableTaskId ? runtime.durableTaskId : undefined;
+}
+
+export function runtimeDurableTaskIds(runtime: { durableTaskId?: string; durableTaskIds?: string[] } | RuntimeVisibilityItem | undefined): string[] {
+	if (!runtime) return [];
+	const singular = "durableTaskId" in runtime && typeof runtime.durableTaskId === "string" && runtime.durableTaskId ? runtime.durableTaskId : undefined;
+	const plural = "durableTaskIds" in runtime && Array.isArray(runtime.durableTaskIds)
+		? runtime.durableTaskIds.filter((id): id is string => typeof id === "string" && id.length > 0)
+		: [];
+	return [...new Set([...(singular ? [singular] : []), ...plural])];
+}
+
+export function runtimeDurableTaskIdsForItems(items: Array<{ durableTaskId?: string; durableTaskIds?: string[] } | RuntimeVisibilityItem | undefined>): string[] {
+	return [...new Set(items.flatMap((item) => runtimeDurableTaskIds(item)))];
+}
+
+function runtimeMatchesTask(runtime: RuntimeVisibilityItem, task: UiTaskDisplay): boolean {
+	const durableTaskIds = runtimeDurableTaskIds(runtime);
+	if (durableTaskIds.length > 0) return durableTaskIds.includes(task.taskId);
+	const agent = "agent" in runtime ? runtime.agent : undefined;
+	return Boolean(agent && (agent === task.activeAgentId || agent === task.targetAgent));
+}
+
+export function isTerminalDurableStatus(status: DurableTaskStatus | undefined): boolean {
+	return Boolean(status && TERMINAL_DURABLE_STATUSES.has(status));
+}
+
+function terminalStatusForStatuses(statuses: DurableTaskStatus[]): DurableTaskStatus | undefined {
+	if (statuses.length === 0 || statuses.some((status) => !isTerminalDurableStatus(status))) return undefined;
+	return statuses.find((status) => status === "failed")
+		?? statuses.find((status) => status === "blocked")
+		?? statuses.find((status) => status === "completed");
+}
+
+function durableStatusesFromProjection(projection: UiTaskProjection, ids: string[]): DurableTaskStatus[] {
+	if (projection.degradedReason || ids.length === 0) return [];
+	return ids
+		.map((id) => projection.tasks.find((task) => task.taskId === id)?.durableStatus)
+		.filter((status): status is DurableTaskStatus => Boolean(status));
+}
+
+function durableStatusFromProjection(projection: UiTaskProjection, item: { durableTaskId?: string; durableTaskIds?: string[] } | RuntimeVisibilityItem | undefined): DurableTaskStatus | undefined {
+	const idStatuses = durableStatusesFromProjection(projection, runtimeDurableTaskIds(item));
+	if (idStatuses.length > 0) return terminalStatusForStatuses(idStatuses) ?? idStatuses.find(Boolean);
+	const agent = item && "agent" in item ? item.agent : undefined;
+	if (!agent || projection.degradedReason) return undefined;
+	const agentStatuses = projection.tasks
+		.filter((task) => agent === task.activeAgentId || agent === task.targetAgent)
+		.map((task) => task.durableStatus);
+	return agentStatuses.find((status) => status === "in-progress") ?? terminalStatusForStatuses(agentStatuses) ?? agentStatuses.find(Boolean);
+}
+
+export interface UiRuntimeArbitration {
+	hasDurableTaskIds: boolean;
+	durableTaskIds: string[];
+	durableStatuses: DurableTaskStatus[];
+	terminalDurableStatus?: DurableTaskStatus;
+	matchedTask?: UiTaskDisplay;
+	degradedReason?: string;
+	canShowActive: boolean;
+	effectiveStatus: "pending" | "in-progress" | "completed" | "blocked" | "failed" | "degraded" | "runtime";
+	activityTitle?: string;
+}
+
+export function arbitrateRuntimeUiActivity(input: {
+	taskStatePath?: string;
+	runtimeItems?: Array<{ durableTaskId?: string; durableTaskIds?: string[]; agent?: string; status?: string; roleLabel?: string } | RuntimeVisibilityItem | undefined>;
+	runtimeStatus?: string;
+	projection?: UiTaskProjection;
+}): UiRuntimeArbitration {
+	const runtimeItems = input.runtimeItems ?? [];
+	const durableTaskIds = runtimeDurableTaskIdsForItems(runtimeItems);
+	const hasDurableTaskIds = durableTaskIds.length > 0;
+	if (hasDurableTaskIds && !input.taskStatePath && !input.projection) {
+		return {
+			hasDurableTaskIds,
+			durableTaskIds,
+			durableStatuses: [],
+			degradedReason: "BMAD task state artifact path was not provided",
+			canShowActive: false,
+			effectiveStatus: "degraded",
+		};
+	}
+	const projection = input.projection ?? (input.taskStatePath ? readDurableTaskProjection(input.taskStatePath) : undefined);
+	if (projection?.degradedReason) {
+		return {
+			hasDurableTaskIds,
+			durableTaskIds,
+			durableStatuses: [],
+			degradedReason: projection.degradedReason,
+			canShowActive: false,
+			effectiveStatus: "degraded",
+		};
+	}
+	const agentMatchedStatuses = !hasDurableTaskIds && projection && !projection.degradedReason
+		? projection.tasks
+			.filter((task) => runtimeItems.some((runtime) => runtime && "agent" in runtime && runtime.agent && (runtime.agent === task.activeAgentId || runtime.agent === task.targetAgent)))
+			.map((task) => task.durableStatus)
+		: [];
+	const durableStatuses = projection ? (hasDurableTaskIds ? durableStatusesFromProjection(projection, durableTaskIds) : agentMatchedStatuses) : [];
+	if (hasDurableTaskIds && durableStatuses.length === 0) {
+		return {
+			hasDurableTaskIds,
+			durableTaskIds,
+			durableStatuses,
+			degradedReason: `BMAD task state artifact has no matching durable task for ${durableTaskIds.join(", ")}`,
+			canShowActive: false,
+			effectiveStatus: "degraded",
+		};
+	}
+	const hasRuntimeAgent = runtimeItems.some((runtime) => runtime && "agent" in runtime && Boolean(runtime.agent));
+	const matchedTask = projection?.tasks.find((task) => durableTaskIds.includes(task.taskId) && task.durableStatus === "in-progress")
+		?? projection?.tasks.find((task) => task.durableStatus === "in-progress" && runtimeItems.some((runtime) => runtime && "agent" in runtime && (runtime.agent === task.activeAgentId || runtime.agent === task.targetAgent)))
+		?? (!hasDurableTaskIds && !hasRuntimeAgent ? projection?.tasks.find((task) => task.durableStatus === "in-progress") : undefined);
+	const terminalDurableStatus = terminalStatusForStatuses(durableStatuses);
+	const canShowActive = Boolean(matchedTask && (!hasDurableTaskIds || durableStatuses.includes("in-progress")));
+	const effectiveStatus = canShowActive
+		? "in-progress"
+		: terminalDurableStatus
+			? terminalDurableStatus
+			: durableStatuses.find((status) => status === "pending")
+				?? durableStatuses.find(Boolean)
+				?? (input.runtimeStatus ? "runtime" : "pending");
+	return {
+		hasDurableTaskIds,
+		durableTaskIds,
+		durableStatuses,
+		terminalDurableStatus,
+		matchedTask,
+		canShowActive,
+		effectiveStatus,
+		activityTitle: canShowActive ? matchedTask?.activityTitle : undefined,
+	};
+}
+
+export function durableStatusForRuntimeItem(taskStatePath: string | undefined, item: { durableTaskId?: string; durableTaskIds?: string[] } | RuntimeVisibilityItem | undefined): DurableTaskStatus | undefined {
+	if (!taskStatePath || runtimeDurableTaskIds(item).length === 0) return undefined;
+	return durableStatusFromProjection(readDurableTaskProjection(taskStatePath), item);
+}
+
+export function durableStatusForRuntimeItems(taskStatePath: string | undefined, items: Array<{ durableTaskId?: string; durableTaskIds?: string[] } | RuntimeVisibilityItem | undefined>): DurableTaskStatus | undefined {
+	if (!taskStatePath) return undefined;
+	const projection = readDurableTaskProjection(taskStatePath);
+	for (const item of items) {
+		const status = durableStatusFromProjection(projection, item);
+		if (isTerminalDurableStatus(status)) return status;
+	}
+	return items.map((item) => durableStatusFromProjection(projection, item)).find(Boolean);
+}
+
+export function durableStatusesForRuntimeItems(taskStatePath: string | undefined, items: Array<{ durableTaskId?: string; durableTaskIds?: string[] } | RuntimeVisibilityItem | undefined>): DurableTaskStatus[] {
+	if (!taskStatePath) return [];
+	const projection = readDurableTaskProjection(taskStatePath);
+	if (projection.degradedReason) return [];
+	return durableStatusesFromProjection(projection, runtimeDurableTaskIdsForItems(items));
+}
+
+export function enrichTaskProjection(projection: UiTaskProjection, runtimeItems: Array<AgentProgress | SingleResult | AsyncJobState | AsyncRuntimeStep | undefined>): UiTaskProjection {
+	if (projection.degradedReason) return projection;
+	const runtimes = runtimeItems.filter(Boolean) as RuntimeVisibilityItem[];
+	const tasks = projection.tasks.map((task) => {
+		const runtime = runtimes.find((item) => runtimeDurableTaskId(item) === task.taskId)
+			?? runtimes.find((item) => runtimeMatchesTask(item, task));
+		const fallbackRoleLabel = task.roleLabel ?? task.activeAgentId ?? task.targetAgent;
+		const roleLabel = runtime ? runtimeRoleLabel(runtime as { roleLabel?: string; agent?: string }, fallbackRoleLabel) : fallbackRoleLabel;
+		const runtimeStatus = runtime && "status" in runtime ? String(runtime.status) : undefined;
+		const active = task.durableStatus === "in-progress";
+		return {
+			...task,
+			roleLabel,
+			activityTitle: formatActivityTitle({ roleLabel, taskId: task.taskId, title: task.title }),
+			...(runtimeStatus ? { runtimeStatus } : {}),
+			...(runtime && "model" in runtime && runtime.model ? { model: runtime.model } : {}),
+			...(runtime && "taskSummary" in runtime && runtime.taskSummary ? { taskSummary: sanitizeUiTitle(runtime.taskSummary, 80) } : {}),
+			...(runtime && "currentTool" in runtime && runtime.currentTool && active ? { currentTool: runtime.currentTool, currentOperation: runtime.currentTool } : {}),
+			...(runtime && "currentPath" in runtime && runtime.currentPath && active ? { currentPath: runtime.currentPath } : {}),
+			...(runtime && "tokens" in runtime && typeof runtime.tokens === "number" ? { tokenCount: runtime.tokens } : {}),
+			...(runtime && "tokens" in runtime && typeof runtime.tokens === "object" && runtime.tokens?.total ? { tokenCount: runtime.tokens.total } : {}),
+			...(runtime && "durationMs" in runtime && typeof runtime.durationMs === "number" ? { elapsedMs: runtime.durationMs } : {}),
+		};
+	});
+	return { tasks };
+}
+
+export function buildRuntimeActivityTitle(input: { details?: { taskStatePath?: string; progress?: AgentProgress[]; results?: SingleResult[] }; job?: AsyncJobState }, maxLength = 120): string | undefined {
+	const runtime = input.job?.steps?.find((step) => step.status === "running")
+		?? input.job?.steps?.[0]
+		?? choosePrimaryRuntimeProgress(input.details ?? {});
+	const taskStatePath = input.details?.taskStatePath ?? input.job?.taskStatePath;
+	const runtimeItems = [runtime, input.job].filter(Boolean) as RuntimeVisibilityItem[];
+	const durableTaskIds = runtimeDurableTaskIdsForItems(runtimeItems);
+	const runtimeStatus = input.job?.status ?? (runtime && "status" in runtime ? String(runtime.status) : undefined);
+	const arbitration = arbitrateRuntimeUiActivity({ taskStatePath, runtimeItems, runtimeStatus });
+	if (arbitration.degradedReason && durableTaskIds.length > 0) return undefined;
+	if (arbitration.activityTitle) return sanitizeUiTitle(arbitration.activityTitle, maxLength);
+	if (arbitration.terminalDurableStatus) return undefined;
+	if (durableTaskIds.length > 0 && !arbitration.canShowActive) return undefined;
+	if (taskStatePath) {
+		const projection = enrichTaskProjection(readDurableTaskProjection(taskStatePath), runtimeItems);
+		if (projection.degradedReason) return formatActivityTitle({ roleLabel: runtimeRoleLabel(runtime as { roleLabel?: string; agent?: string }, runtimeAgentId(runtime)), degradedReason: projection.degradedReason }, maxLength);
+		const activeTask = projection.tasks.find((task) => task.durableStatus === "in-progress" && (runtimeAgentId(runtime) === task.activeAgentId || runtimeAgentId(runtime) === task.targetAgent))
+			?? projection.tasks.find((task) => task.durableStatus === "in-progress");
+		if (activeTask) return sanitizeUiTitle(activeTask.activityTitle, maxLength);
+	}
+	const roleLabel = runtimeRoleLabel(runtime as { roleLabel?: string; agent?: string }, runtimeAgentId(runtime));
+	const summary = runtimeTaskSummary(runtime as AgentProgress | SingleResult | undefined) || "subagent activity";
+	const taskId = input.job?.asyncId ?? "runtime";
+	return formatActivityTitle({ roleLabel, taskId, title: summary }, maxLength);
+}
+
+export function formatRuntimeAnnotation(input: { runtimeStatus?: string; currentTool?: string; currentOperation?: string; currentPath?: string; tokenCount?: number; elapsedMs?: number; model?: string; taskSummary?: string }): string {
+	const parts = [
+		input.runtimeStatus,
+		input.currentOperation ?? input.currentTool,
+		input.currentPath ? shortenPath(input.currentPath) : undefined,
+		input.model,
+		input.tokenCount !== undefined ? formatTokens(input.tokenCount) + " token" : undefined,
+		input.elapsedMs !== undefined ? formatDuration(input.elapsedMs) : undefined,
+	].filter((part): part is string => Boolean(part));
+	return sanitizeUiTitle(parts.join(" · "), 160);
+}
